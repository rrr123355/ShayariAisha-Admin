<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#00BCD4">
    <title>Manage Your Shayari Collection</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- ✅ GOOGLE FONTS FOR UNICODE -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500&family=Noto+Sans+Symbols:wght@400&family=Noto+Sans+Symbols+2:wght@400&family=Noto+Color+Emoji&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Noto Sans', 'Noto Sans JP', 'Noto Sans Symbols', 'Noto Sans Symbols 2', 'Noto Color Emoji', -apple-system, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 15px;
            padding-bottom: 80px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            background: linear-gradient(135deg, #00BCD4, #0097A7);
            padding: 20px;
            border-radius: 20px;
            margin-bottom: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .header h1 {
            color: white;
            font-size: 24px;
            font-weight: 900;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header p {
            color: rgba(255,255,255,0.9);
            font-size: 13px;
            font-weight: 600;
        }

        /* ✅ API KEY SETTINGS */
        .api-settings {
            background: white;
            padding: 15px;
            border-radius: 15px;
            margin-bottom: 15px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.1);
        }

        .api-settings h3 {
            color: #2C3E50;
            font-size: 14px;
            font-weight: 800;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .api-settings input {
            width: 100%;
            padding: 10px 12px;
            border: 2px solid #E0E0E0;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 500;
            background: #F8F9FA;
        }

        .api-settings input:focus {
            border-color: #00BCD4;
            box-shadow: 0 0 0 3px rgba(0, 188, 212, 0.1);
            outline: none;
        }

        .api-settings .hint {
            margin-top: 8px;
            font-size: 11px;
            color: #7F8C8D;
            font-weight: 600;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: white;
            padding: 18px;
            border-radius: 15px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.1);
        }

        .stat-card h3 {
            color: #7F8C8D;
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .stat-card .stat-value {
            color: #2C3E50;
            font-size: 26px;
            font-weight: 900;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .stat-card .stat-value i {
            font-size: 22px;
            color: #00BCD4;
        }

        .api-status {
            background: linear-gradient(135deg, #4CAF50, #388E3C);
            color: white;
            padding: 12px 15px;
            border-radius: 12px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            font-weight: 700;
            box-shadow: 0 4px 15px rgba(76, 175, 80, 0.3);
        }

        .api-status i {
            font-size: 18px;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .info-box {
            background: linear-gradient(135deg, #FFF3CD, #FFE8A1);
            padding: 12px 15px;
            border-radius: 12px;
            margin-bottom: 20px;
            border-left: 4px solid #FFC107;
        }

        .info-box p {
            color: #856404;
            font-size: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 20px;
            margin-bottom: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        }

        .card h2 {
            color: #2C3E50;
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .author-preview {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px;
            background: linear-gradient(135deg, #f8f9fa, #ffffff);
            border-radius: 15px;
            margin-bottom: 15px;
            border: 2px solid #E0E0E0;
        }

        .author-preview img {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #00BCD4;
        }

        .author-preview-info h3 {
            color: #2C3E50;
            font-size: 15px;
            font-weight: 700;
            margin-bottom: 3px;
        }

        .author-preview-info p {
            color: #7F8C8D;
            font-size: 11px;
            font-weight: 600;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            color: #2C3E50;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px 15px;
            background: white;
            border: 2px solid #E0E0E0;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s ease;
            color: #2C3E50;
        }

        .form-group textarea {
            width: 100%;
            padding: 15px;
            background: white;
            border: 2px solid #E0E0E0;
            border-radius: 12px;
            font-size: 17px !important;
            min-height: 130px;
            resize: vertical;
            line-height: 1.8;
            transition: all 0.3s ease;
            color: #2C3E50;
            font-family: 'Noto Sans', 'Noto Sans JP', 'Noto Sans Symbols', 'Noto Sans Symbols 2', 'Noto Color Emoji', sans-serif !important;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            border-color: #00BCD4;
            box-shadow: 0 0 0 3px rgba(0, 188, 212, 0.1);
            outline: none;
        }

        .upload-box {
            background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
            padding: 20px;
            border-radius: 12px;
            border: 2px dashed #4CAF50;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 12px;
        }

        .upload-box:hover {
            background: linear-gradient(135deg, #C8E6C9, #A5D6A7);
            border-color: #388E3C;
        }

        .upload-box i {
            font-size: 40px;
            color: #4CAF50;
            margin-bottom: 10px;
        }

        .upload-box h4 {
            color: #2C3E50;
            font-size: 15px;
            font-weight: 800;
            margin-bottom: 5px;
        }

        .upload-box p {
            color: #7F8C8D;
            font-size: 12px;
            font-weight: 600;
        }

        .upload-box input[type="file"] {
            display: none;
        }

        .image-preview {
            margin-top: 12px;
            padding: 12px;
            background: white;
            border-radius: 10px;
            display: none;
        }

        .image-preview img {
            width: 100%;
            max-height: 200px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 8px;
        }

        .image-preview .status {
            font-size: 11px;
            font-weight: 700;
            color: #4CAF50;
        }

        .image-preview .status.error {
            color: #E74C3C;
        }

        /* ✅ IMAGE GALLERY FROM FIREBASE */
        .image-gallery {
            background: linear-gradient(135deg, #F3E5F5, #E1BEE7);
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 12px;
            border-left: 4px solid #9C27B0;
            display: none;
        }

        .image-gallery.show {
            display: block;
        }

        .image-gallery h4 {
            color: #4A148C;
            font-size: 13px;
            font-weight: 800;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .gallery-item {
            position: relative;
            border-radius: 10px;
            overflow: hidden;
            cursor: pointer;
            border: 3px solid transparent;
            transition: all 0.3s ease;
        }

        .gallery-item:hover {
            transform: scale(1.05);
        }

        .gallery-item.selected {
            border-color: #9C27B0;
            box-shadow: 0 0 0 3px rgba(156, 39, 176, 0.2);
        }

        .gallery-item img {
            width: 100%;
            height: 100px;
            object-fit: cover;
            display: block;
        }

        .gallery-item .check-icon {
            position: absolute;
            top: 5px;
            right: 5px;
            background: #9C27B0;
            color: white;
            width: 25px;
            height: 25px;
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 12px;
        }

        .gallery-item.selected .check-icon {
            display: flex;
        }

        /* ✅ MANUAL URL INPUT */
        .manual-url-box {
            background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
            padding: 15px;
            border-radius: 12px;
            margin-top: 10px;
            border-left: 4px solid #2196F3;
        }

        .manual-url-box label {
            display: block;
            color: #1565C0;
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .manual-url-box input {
            width: 100%;
            padding: 10px 12px;
            border: 2px solid #90CAF9;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            background: white;
        }

        .manual-url-box input:focus {
            border-color: #2196F3;
            box-shadow: 0 0 0 3px rgba(33, 150, 243, 0.1);
            outline: none;
        }

        .btn-save {
            width: 100%;
            background: linear-gradient(135deg, #00BCD4, #0097A7);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 900;
            cursor: pointer;
            margin-top: 15px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(0, 188, 212, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-save:active {
            transform: scale(0.98);
        }

        .btn-publish {
            width: 100%;
            background: linear-gradient(135deg, #E74C3C, #C0392B);
            color: white;
            border: none;
            padding: 16px;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 900;
            cursor: pointer;
            margin-top: 20px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            box-shadow: 0 4px 15px rgba(231, 76, 60, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-publish:active {
            transform: scale(0.98);
        }

        /* ✅ UPDATE BUTTON FOR EDIT MODE */
        .btn-update {
            width: 100%;
            background: linear-gradient(135deg, #F39C12, #E67E22);
            color: white;
            border: none;
            padding: 16px;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 900;
            cursor: pointer;
            margin-top: 20px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            box-shadow: 0 4px 15px rgba(243, 156, 18, 0.3);
            display: none;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-update.show {
            display: flex;
        }

        .btn-update:active {
            transform: scale(0.98);
        }

        /* ✅ CANCEL EDIT BUTTON */
        .btn-cancel {
            width: 100%;
            background: linear-gradient(135deg, #95A5A6, #7F8C8D);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 900;
            cursor: pointer;
            margin-top: 10px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: none;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-cancel.show {
            display: flex;
        }

        .btn-cancel:active {
            transform: scale(0.98);
        }

        .shayari-list {
            margin-top: 20px;
        }

        .shayari-item {
            background: #F8F9FA;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 12px;
            border: 2px solid #E0E0E0;
            transition: all 0.3s ease;
        }

        .shayari-item:hover {
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .shayari-item-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
        }

        .author-small {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .author-small img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #00BCD4;
        }

        .author-small div h4 {
            color: #2C3E50;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .author-small div p {
            color: #7F8C8D;
            font-size: 10px;
            font-weight: 600;
        }

        .action-btns {
            display: flex;
            gap: 8px;
        }

        .btn-edit,
        .btn-delete {
            color: white;
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 10px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-edit {
            background: linear-gradient(135deg, #F39C12, #E67E22);
        }

        .btn-delete {
            background: linear-gradient(135deg, #E74C3C, #C0392B);
        }

        .btn-edit:active,
        .btn-delete:active {
            transform: scale(0.9);
        }

        .shayari-item-image {
            width: 100%;
            max-height: 200px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 10px;
        }

        .shayari-item-text {
            color: #2C3E50;
            font-size: 14px;
            font-weight: 500;
            line-height: 1.7;
            margin-bottom: 10px;
            white-space: pre-wrap;
            word-wrap: break-word;
            font-family: 'Noto Sans', 'Noto Sans JP', 'Noto Sans Symbols', 'Noto Sans Symbols 2', 'Noto Color Emoji', sans-serif;
        }

        .shayari-item-tags {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        .tag {
            background: linear-gradient(135deg, #00BCD4, #0097A7);
            color: white;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .toast {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%) translateY(-100px);
            background: linear-gradient(135deg, #4CAF50, #388E3C);
            color: white;
            padding: 12px 25px;
            border-radius: 25px;
            font-weight: 800;
            font-size: 13px;
            z-index: 4000;
            opacity: 0;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }

        .toast.error {
            background: linear-gradient(135deg, #E74C3C, #C0392B);
        }

        .loading {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            z-index: 5000;
            justify-content: center;
            align-items: center;
        }

        .loading.show {
            display: flex;
        }

        .loading-content {
            background: white;
            padding: 30px;
            border-radius: 20px;
            text-align: center;
        }

        .loading-content i {
            font-size: 40px;
            color: #00BCD4;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .loading-content p {
            color: #2C3E50;
            font-weight: 700;
            margin-top: 15px;
            font-size: 14px;
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
        }

        .empty-state i {
            font-size: 50px;
            color: #E0E0E0;
            margin-bottom: 15px;
        }

        .empty-state p {
            color: #7F8C8D;
            font-weight: 600;
            font-size: 14px;
        }

        /* ✅ EDIT MODE INDICATOR */
        .edit-mode-badge {
            background: linear-gradient(135deg, #F39C12, #E67E22);
            color: white;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 800;
            display: none;
            align-items: center;
            gap: 8px;
            margin-bottom: 15px;
            animation: pulse 2s infinite;
        }

        .edit-mode-badge.show {
            display: flex;
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1><i class="fas fa-feather-alt"></i> Shayari Admin Panel</h1>
            <p>Manage Your Shayari Collection</p>
        </div>

        <!-- ✅ API KEY SETTINGS -->
        <div class="api-settings">
            <h3><i class="fas fa-key"></i> IMGBB API KEY</h3>
            <input type="text" id="imgbbApiKey" value="9d0dc3093c6e1c78f89fd149ceaf2688" placeholder="Enter your ImgBB API key">
            <p class="hint"><i class="fas fa-info-circle"></i> Get free API key from imgbb.com/api</p>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <h3>Total Shayari</h3>
                <div class="stat-value">
                    <i class="fas fa-book"></i>
                    <span id="totalShayari">0</span>
                </div>
            </div>
            <div class="stat-card">
                <h3>Published Today</h3>
                <div class="stat-value">
                    <i class="fas fa-calendar-day"></i>
                    <span id="todayShayari">0</span>
                </div>
            </div>
        </div>

        <!-- API Status -->
        <div class="api-status">
            <i class="fas fa-check-circle"></i>
            <span>Active & Working</span>
        </div>

        <!-- Info Box -->
        <div class="info-box">
            <p>
                <i class="fas fa-info-circle"></i>
                Select category to see previous images
            </p>
        </div>

        <!-- Author Profile Card -->
        <div class="card">
            <h2><i class="fas fa-user-circle"></i> Default Author Profile</h2>
            <div class="author-preview">
                <img src="https://ui-avatars.com/api/?name=Author&background=00BCD4&color=fff&size=100" alt="Author" id="previewImg">
                <div class="author-preview-info">
                    <h3 id="previewName">Your Name</h3>
                    <p>Default Profile</p>
                </div>
            </div>
            
            <div class="form-group">
                <label><i class="fas fa-signature"></i> Author Name *</label>
                <input type="text" id="authorName" placeholder="Enter your name">
            </div>

            <div class="form-group">
                <label><i class="fas fa-camera"></i> Profile Picture</label>
                <div class="upload-box" onclick="document.getElementById('profilePhotoInput').click()">
                    <i class="fas fa-cloud-upload-alt"></i>
                    <h4>Upload Profile Photo</h4>
                    <p>Click to choose from gallery</p>
                    <input type="file" id="profilePhotoInput" accept="image/*" onchange="uploadProfilePhoto(event)">
                    <div class="image-preview" id="profilePreview">
                        <img src="" alt="Preview" id="profilePreviewImg">
                        <p class="status" id="profileStatus">Uploading...</p>
                    </div>
                </div>
                <input type="text" id="authorPhoto" placeholder="Photo URL (auto-generated)" readonly style="background: #f5f5f5; margin-top: 10px;">
            </div>
            
            <button class="btn-save" onclick="saveAuthorProfile()">
                <i class="fas fa-save"></i> Save Profile
            </button>
        </div>

        <!-- Add/Edit Shayari Card -->
        <div class="card" id="shayariForm">
            <h2><i class="fas fa-pen-fancy"></i> <span id="formTitle">Add New Shayari</span></h2>
            
            <!-- ✅ EDIT MODE INDICATOR -->
            <div class="edit-mode-badge" id="editModeBadge">
                <i class="fas fa-edit"></i>
                <span>EDIT MODE - Updating Shayari</span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-quote-left"></i> ♡♡ SHAYARI TEXT *</label>
                <textarea id="shayariText" placeholder="Write your shayari with symbols... ♡゚---------- ✨"></textarea>
            </div>

            <div class="form-group">
                <label><i class="fas fa-tags"></i> ♨ CATEGORY *</label>
                <select id="category" onchange="loadCategoryImages()">
                    <option value="">Choose Category</option>
                    <option value="Love">Love</option>
                    <option value="Sad">Sad</option>
                    <option value="Attitude">Attitude</option>
                    <option value="Friendship">Friendship</option>
                    <option value="Motivational">Motivational</option>
                </select>
            </div>

            <!-- ✅ IMAGE GALLERY FROM FIREBASE -->
            <div class="image-gallery" id="imageGallery">
                <h4><i class="fas fa-images"></i> Choose from Previous Images (<span id="imageCount">0</span> available)</h4>
                <div class="gallery-grid" id="galleryGrid">
                    <!-- Images will be loaded here -->
                </div>
            </div>

            <div class="form-group">
                <label><i class="fas fa-language"></i> 🅰 LANGUAGE *</label>
                <select id="language">
                    <option value="">Select Language</option>
                    <option value="English">English</option>
                    <option value="Hindi">Hindi</option>
                </select>
            </div>

            <div class="form-group">
                <label><i class="fas fa-heart"></i> MOOD *</label>
                <select id="mood">
                    <option value="Romantic">Romantic</option>
                    <option value="Melancholic">Melancholic</option>
                    <option value="Inspirational">Inspirational</option>
                    <option value="Joyful">Joyful</option>
                    <option value="Reflective">Reflective</option>
                    <option value="Passionate">Passionate</option>
                </select>
            </div>

            <div class="form-group">
                <label><i class="fas fa-image"></i> SHAYARI IMAGE</label>
                
                <!-- Upload Box -->
                <div class="upload-box" onclick="document.getElementById('shayariImageInput').click()">
                    <i class="fas fa-cloud-upload-alt"></i>
                    <h4>Upload Image</h4>
                    <p>Click to choose</p>
                    <input type="file" id="shayariImageInput" accept="image/*" onchange="uploadShayariImage(event)">
                    <div class="image-preview" id="shayariPreview">
                        <img src="" alt="Preview" id="shayariPreviewImg">
                        <p class="status" id="shayariStatus">Uploading...</p>
                    </div>
                </div>

                <!-- ✅ MANUAL URL INPUT -->
                <div class="manual-url-box">
                    <label><i class="fas fa-link"></i> Or Paste Image URL Manually</label>
                    <input type="text" id="imageUrl" placeholder="https://example.com/image.jpg" oninput="previewManualUrl()">
                </div>
            </div>

            <!-- ✅ PUBLISH / UPDATE BUTTONS -->
            <button class="btn-publish" id="publishBtn" onclick="publishShayari()">
                <i class="fas fa-paper-plane"></i> PUBLISH SHAYARI
            </button>

            <button class="btn-update" id="updateBtn" onclick="updateShayari()">
                <i class="fas fa-save"></i> UPDATE SHAYARI
            </button>

            <button class="btn-cancel" id="cancelBtn" onclick="cancelEdit()">
                <i class="fas fa-times"></i> CANCEL EDIT
            </button>
        </div>

        <!-- Published Shayari List -->
        <div class="card">
            <h2><i class="fas fa-list"></i> Published Shayari</h2>
            <div id="shayariListContainer">
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>No shayari yet</p>
                </div>
            </div>
        </div>
    </div>

    <div class="toast" id="toast"></div>
    
    <div class="loading" id="loading">
        <div class="loading-content">
            <i class="fas fa-circle-notch"></i>
            <p id="loadingText">Loading...</p>
        </div>
    </div>

    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>

    <script>
        const firebaseConfig = {
            apiKey: "AIzaSyDpLakcRDEo9UMuRw3WWkBgW8EkwiQ_Ouw",
            authDomain: "aishagameapp.firebaseapp.com",
            databaseURL: "https://aishagameapp-default-rtdb.firebaseio.com",
            projectId: "aishagameapp",
            storageBucket: "aishagameapp.firebasestorage.app",
            messagingSenderId: "1079958025420",
            appId: "1:1079958025420:web:d6f328a107cd51bb487e69",
            measurementId: "G-N6QH06L4N5"
        };

        firebase.initializeApp(firebaseConfig);
        const database = firebase.database();

        // ✅ EDIT MODE VARIABLES
        let editMode = false;
        let currentEditId = null;

        // ✅ LOAD CATEGORY IMAGES FROM FIREBASE
        function loadCategoryImages() {
            const category = document.getElementById('category').value;
            if (!category) {
                document.getElementById('imageGallery').classList.remove('show');
                return;
            }

            showLoading('Loading category images...');

            // ✅ FETCH ALL SHAYARI OF THIS CATEGORY
            database.ref('shayari').orderByChild('category').equalTo(category).once('value', (snapshot) => {
                const data = snapshot.val();
                const galleryGrid = document.getElementById('galleryGrid');
                const imageGallery = document.getElementById('imageGallery');

                if (!data) {
                    imageGallery.classList.remove('show');
                    hideLoading();
                    return;
                }

                // ✅ COLLECT UNIQUE IMAGES
                const uniqueImages = new Set();
                Object.values(data).forEach(item => {
                    if (item.imageUrl && item.imageUrl.trim()) {
                        uniqueImages.add(item.imageUrl);
                    }
                });

                if (uniqueImages.size === 0) {
                    imageGallery.classList.remove('show');
                    hideLoading();
                    return;
                }

                // ✅ DISPLAY IMAGES
                document.getElementById('imageCount').textContent = uniqueImages.size;
                galleryGrid.innerHTML = '';
                
                uniqueImages.forEach(url => {
                    const item = document.createElement('div');
                    item.className = 'gallery-item';
                    item.innerHTML = `
                        <img src="${url}" alt="Image">
                        <div class="check-icon"><i class="fas fa-check"></i></div>
                    `;
                    
                    item.addEventListener('click', () => {
                        // Remove previous selection
                        document.querySelectorAll('.gallery-item').forEach(el => el.classList.remove('selected'));
                        // Select this item
                        item.classList.add('selected');
                        // Set URL
                        document.getElementById('imageUrl').value = url;
                        document.getElementById('shayariPreviewImg').src = url;
                        document.getElementById('shayariPreview').style.display = 'block';
                        document.getElementById('shayariStatus').textContent = '✓ Image selected!';
                        document.getElementById('shayariStatus').classList.remove('error');
                        showToast('✅ Image selected!');
                    });
                    
                    galleryGrid.appendChild(item);
                });

                imageGallery.classList.add('show');
                hideLoading();
            }).catch((error) => {
                hideLoading();
                console.error('Error loading category images:', error);
            });
        }

        // ✅ UPLOAD IMAGE TO IMGBB
        async function uploadToImgBB(file, statusId, previewId, urlFieldId) {
            return new Promise((resolve, reject) => {
                if (!file.type.startsWith('image/')) {
                    reject('Please select an image file!');
                    return;
                }

                if (file.size > 10 * 1024 * 1024) {
                    reject('Image too large! Max 10MB');
                    return;
                }

                const apiKey = document.getElementById('imgbbApiKey').value.trim();
                if (!apiKey) {
                    reject('Please enter ImgBB API key!');
                    return;
                }

                const reader = new FileReader();
                reader.onload = function(e) {
                    const preview = document.getElementById(previewId);
                    if (preview) {
                        preview.style.display = 'block';
                        const img = preview.querySelector('img');
                        if (img) img.src = e.target.result;
                        const status = document.getElementById(statusId);
                        if (status) {
                            status.textContent = 'Uploading...';
                            status.classList.remove('error');
                        }
                    }
                };
                reader.readAsDataURL(file);

                const reader2 = new FileReader();
                reader2.onloadend = async function() {
                    try {
                        const base64String = reader2.result.split(',')[1];
                        showLoading('Uploading image...');

                        const formData = new FormData();
                        formData.append('key', apiKey);
                        formData.append('image', base64String);

                        const response = await fetch('https://api.imgbb.com/1/upload', {
                            method: 'POST',
                            body: formData
                        });

                        const data = await response.json();

                        if (data.success) {
                            const imageUrl = data.data.image.url;
                            document.getElementById(urlFieldId).value = imageUrl;
                            
                            const status = document.getElementById(statusId);
                            if (status) {
                                status.textContent = '✓ Uploaded!';
                                status.classList.remove('error');
                            }

                            hideLoading();
                            showToast('✅ Image uploaded!');
                            resolve(imageUrl);
                        } else {
                            throw new Error(data.error?.message || 'Upload failed');
                        }
                    } catch (error) {
                        console.error('Upload error:', error);
                        const status = document.getElementById(statusId);
                        if (status) {
                            status.textContent = '✗ Upload failed!';
                            status.classList.add('error');
                        }
                        hideLoading();
                        showToast('❌ Upload failed!', true);
                        reject(error);
                    }
                };
                reader2.readAsDataURL(file);
            });
        }

        async function uploadProfilePhoto(event) {
            const file = event.target.files[0];
            if (!file) return;

            try {
                await uploadToImgBB(file, 'profileStatus', 'profilePreview', 'authorPhoto');
                const url = document.getElementById('authorPhoto').value;
                document.getElementById('previewImg').src = url;
            } catch (error) {
                console.error(error);
            }
        }

        async function uploadShayariImage(event) {
            const file = event.target.files[0];
            if (!file) return;

            try {
                await uploadToImgBB(file, 'shayariStatus', 'shayariPreview', 'imageUrl');
            } catch (error) {
                console.error(error);
            }
        }

        // ✅ PREVIEW MANUAL URL
        function previewManualUrl() {
            const url = document.getElementById('imageUrl').value.trim();
            if (url) {
                document.getElementById('shayariPreviewImg').src = url;
                document.getElementById('shayariPreview').style.display = 'block';
                document.getElementById('shayariStatus').textContent = '✓ Manual URL loaded!';
                document.getElementById('shayariStatus').classList.remove('error');
            } else {
                document.getElementById('shayariPreview').style.display = 'none';
            }
        }

        function loadAuthorProfile() {
            const savedName = localStorage.getItem('authorName');
            const savedPhoto = localStorage.getItem('authorPhoto');
            
            if (savedName) {
                document.getElementById('authorName').value = savedName;
                document.getElementById('previewName').textContent = savedName;
            }
            
            if (savedPhoto) {
                document.getElementById('authorPhoto').value = savedPhoto;
                document.getElementById('previewImg').src = savedPhoto;
            }
        }

        document.getElementById('authorName').addEventListener('input', function(e) {
            document.getElementById('previewName').textContent = e.target.value || 'Your Name';
        });

        function saveAuthorProfile() {
            const name = document.getElementById('authorName').value.trim();
            const photo = document.getElementById('authorPhoto').value.trim();

            if (!name) {
                showToast('⚠️ Enter your name!', true);
                return;
            }

            localStorage.setItem('authorName', name);
            localStorage.setItem('authorPhoto', photo);
            showToast('✅ Profile saved!');
        }

        function publishShayari() {
            const text = document.getElementById('shayariText').value.trim();
            const category = document.getElementById('category').value;
            const language = document.getElementById('language').value;
            const mood = document.getElementById('mood').value;
            const imageUrl = document.getElementById('imageUrl').value.trim();
            const authorName = localStorage.getItem('authorName') || 'Anonymous';
            const authorPhoto = localStorage.getItem('authorPhoto') || '';

            if (!text || !category || !language) {
                showToast('⚠️ Fill all required fields!', true);
                return;
            }

            showLoading('Publishing...');

            database.ref('shayari').push({
                text: text,
                category: category,
                language: language,
                mood: mood,
                authorName: authorName,
                authorPhoto: authorPhoto,
                imageUrl: imageUrl,
                timestamp: Date.now()
            }).then(() => {
                hideLoading();
                showToast('✅ Published successfully!');
                clearForm();
                updateStats();
            }).catch((error) => {
                hideLoading();
                showToast('❌ Error: ' + error.message, true);
            });
        }

        // ✅ EDIT SHAYARI
        function editShayari(id) {
            showLoading('Loading shayari...');
            
            database.ref('shayari/' + id).once('value', (snapshot) => {
                const data = snapshot.val();
                
                if (!data) {
                    hideLoading();
                    showToast('❌ Shayari not found!', true);
                    return;
                }

                // ✅ SET EDIT MODE
                editMode = true;
                currentEditId = id;

                // ✅ FILL FORM WITH DATA
                document.getElementById('shayariText').value = data.text;
                document.getElementById('category').value = data.category;
                document.getElementById('language').value = data.language;
                document.getElementById('mood').value = data.mood;
                document.getElementById('imageUrl').value = data.imageUrl || '';

                if (data.imageUrl) {
                    document.getElementById('shayariPreviewImg').src = data.imageUrl;
                    document.getElementById('shayariPreview').style.display = 'block';
                    document.getElementById('shayariStatus').textContent = '✓ Current image';
                }

                // ✅ LOAD CATEGORY IMAGES
                loadCategoryImages();

                // ✅ SHOW EDIT MODE UI
                document.getElementById('formTitle').textContent = 'Edit Shayari';
                document.getElementById('editModeBadge').classList.add('show');
                document.getElementById('publishBtn').style.display = 'none';
                document.getElementById('updateBtn').classList.add('show');
                document.getElementById('cancelBtn').classList.add('show');

                // ✅ SCROLL TO FORM
                document.getElementById('shayariForm').scrollIntoView({ behavior: 'smooth', block: 'start' });

                hideLoading();
                showToast('✏️ Edit mode activated!');
            }).catch((error) => {
                hideLoading();
                showToast('❌ Error loading shayari!', true);
                console.error(error);
            });
        }

        // ✅ UPDATE SHAYARI
        function updateShayari() {
            if (!editMode || !currentEditId) {
                showToast('❌ Not in edit mode!', true);
                return;
            }

            const text = document.getElementById('shayariText').value.trim();
            const category = document.getElementById('category').value;
            const language = document.getElementById('language').value;
            const mood = document.getElementById('mood').value;
            const imageUrl = document.getElementById('imageUrl').value.trim();
            const authorName = localStorage.getItem('authorName') || 'Anonymous';
            const authorPhoto = localStorage.getItem('authorPhoto') || '';

            if (!text || !category || !language) {
                showToast('⚠️ Fill all required fields!', true);
                return;
            }

            showLoading('Updating...');

            database.ref('shayari/' + currentEditId).update({
                text: text,
                category: category,
                language: language,
                mood: mood,
                authorName: authorName,
                authorPhoto: authorPhoto,
                imageUrl: imageUrl,
                updatedAt: Date.now()
            }).then(() => {
                hideLoading();
                showToast('✅ Updated successfully!');
                cancelEdit();
                updateStats();
            }).catch((error) => {
                hideLoading();
                showToast('❌ Error: ' + error.message, true);
            });
        }

        // ✅ CANCEL EDIT
        function cancelEdit() {
            editMode = false;
            currentEditId = null;

            // ✅ RESET FORM
            clearForm();

            // ✅ HIDE EDIT MODE UI
            document.getElementById('formTitle').textContent = 'Add New Shayari';
            document.getElementById('editModeBadge').classList.remove('show');
            document.getElementById('publishBtn').style.display = 'flex';
            document.getElementById('updateBtn').classList.remove('show');
            document.getElementById('cancelBtn').classList.remove('show');

            showToast('↩️ Edit cancelled');
        }

        // ✅ DELETE SHAYARI
        function deleteShayari(id) {
            if (!confirm('⚠️ Are you sure you want to delete this shayari? This action cannot be undone!')) {
                return;
            }

            showLoading('Deleting...');
            
            database.ref('shayari/' + id).remove()
                .then(() => {
                    hideLoading();
                    showToast('✅ Deleted successfully!');
                    updateStats();
                })
                .catch((error) => {
                    hideLoading();
                    showToast('❌ Error: ' + error.message, true);
                });
        }

        function loadAllShayari() {
            database.ref('shayari').on('value', (snapshot) => {
                const container = document.getElementById('shayariListContainer');
                const data = snapshot.val();

                if (!data) {
                    container.innerHTML = '<div class="empty-state"><i class="fas fa-inbox"></i><p>No shayari yet</p></div>';
                    return;
                }

                const shayariArray = Object.entries(data).map(([id, item]) => ({ id, ...item })).sort((a, b) => b.timestamp - a.timestamp);

                container.innerHTML = shayariArray.map(item => {
                    const authorImg = item.authorPhoto || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(item.authorName || 'Author') + '&background=00BCD4&color=fff&size=100';
                    const imageHtml = item.imageUrl ? `<img src="${item.imageUrl}" class="shayari-item-image" alt="Shayari">` : '';
                    
                    return `
                        <div class="shayari-item">
                            <div class="shayari-item-header">
                                <div class="author-small">
                                    <img src="${authorImg}" alt="${escapeHtml(item.authorName)}">
                                    <div>
                                        <h4>${escapeHtml(item.authorName)}</h4>
                                        <p>${timeAgo(item.timestamp)}</p>
                                    </div>
                                </div>
                                <div class="action-btns">
                                    <button class="btn-edit" onclick="editShayari('${item.id}')" title="Edit"><i class="fas fa-edit"></i></button>
                                    <button class="btn-delete" onclick="deleteShayari('${item.id}')" title="Delete"><i class="fas fa-trash"></i></button>
                                </div>
                            </div>
                            ${imageHtml}
                            <div class="shayari-item-text">${escapeHtml(item.text)}</div>
                            <div class="shayari-item-tags">
                                <span class="tag">${item.category}</span>
                                <span class="tag">${item.language}</span>
                                <span class="tag">${item.mood}</span>
                            </div>
                        </div>
                    `;
                }).join('');
            });
        }

        function updateStats() {
            database.ref('shayari').once('value', (snapshot) => {
                const data = snapshot.val();
                if (!data) {
                    document.getElementById('totalShayari').textContent = '0';
                    document.getElementById('todayShayari').textContent = '0';
                    return;
                }

                const shayariArray = Object.values(data);
                const today = new Date().setHours(0, 0, 0, 0);
                
                document.getElementById('totalShayari').textContent = shayariArray.length;
                document.getElementById('todayShayari').textContent = shayariArray.filter(s => s.timestamp >= today).length;
            });
        }

        function clearForm() {
            document.getElementById('shayariText').value = '';
            document.getElementById('category').value = '';
            document.getElementById('language').value = '';
            document.getElementById('mood').value = 'Romantic';
            document.getElementById('imageUrl').value = '';
            document.getElementById('shayariPreview').style.display = 'none';
            document.getElementById('imageGallery').classList.remove('show');
        }

        function showToast(message, isError = false) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.classList.toggle('error', isError);
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        function showLoading(text = 'Loading...') {
            document.getElementById('loadingText').textContent = text;
            document.getElementById('loading').classList.add('show');
        }

        function hideLoading() {
            document.getElementById('loading').classList.remove('show');
        }

        function escapeHtml(text) {
            const map = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'};
            return String(text).replace(/[&<>"']/g, m => map[m]);
        }

        function timeAgo(timestamp) {
            const seconds = Math.floor((Date.now() - timestamp) / 1000);
            if (seconds < 60) return 'Just now';
            if (seconds < 3600) return Math.floor(seconds / 60) + ' min ago';
            if (seconds < 86400) return Math.floor(seconds / 3600) + ' hour ago';
            if (seconds < 2592000) return Math.floor(seconds / 86400) + ' day ago';
            return new Date(timestamp).toLocaleDateString();
        }

        window.onload = function() {
            loadAuthorProfile();
            loadAllShayari();
            updateStats();
        };
    </script>

